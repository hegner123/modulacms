{
  "name": "@modulacms/admin-ui",
  "version": "0.0.1",
  "description": "Web Components for building custom ModulaCMS admin panels",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modulacms/types": "workspace:*",
    "@modulacms/admin-sdk": "workspace:*"
  },
  "keywords": [
    "cms",
    "modulacms",
    "admin",
    "web-components",
    "ui",
    "headless-cms"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
