package layouts

templ Auth(title string, csrfToken string, version string) {
	@Base(title, csrfToken, version) {
		<div class="flex min-h-screen items-center justify-center bg-[var(--color-bg)] p-6">
			<div class="w-full max-w-sm rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
				<div class="mb-6 text-center">
					<h1 class="text-2xl font-bold text-[var(--color-text)]">ModulaCMS</h1>
				</div>
				{ children... }
			</div>
		</div>
	}
}
