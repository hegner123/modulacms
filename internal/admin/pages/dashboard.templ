package pages

import "github.com/hegner123/modulacms/internal/admin/layouts"

templ DashboardContent() {
	<div class="page-header">
		<h1>Dashboard</h1>
	</div>
	<div class="dashboard-grid">
		<div class="dashboard-card">
			<h3>Welcome</h3>
			<p>Welcome to ModulaCMS admin panel.</p>
		</div>
	</div>
}

templ Dashboard(layout layouts.AdminData) {
	@layouts.Admin(layout) {
		@DashboardContent()
	}
}
