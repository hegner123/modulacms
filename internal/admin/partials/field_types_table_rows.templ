                <td class="whitespace-nowrap px-4 py-4 text-sm"><code class="rounded bg-white/5 px-1.5 py-0.5 text-xs font-mono text-white">{ ft.Type }</code></td>
                <td class="whitespace-nowrap px-4 py-4 text-sm">
                    <mcms-confirm
                        label="Delete"
