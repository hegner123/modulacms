package partials

import "github.com/hegner123/modulacms/internal/db"

// DatatypeForm renders the create datatype form fields.
// Used as an HTMX partial for validation error responses.
templ DatatypeForm(name string, label string, dtype string, parentID string, allDatatypes []db.Datatypes, errs map[string]string, csrfToken string) {
	@CSRFField(csrfToken)
	if errs["_"] != "" {
		<div class="rounded-md bg-red-500/10 p-4 ring-1 ring-red-400/20 ring-inset">
			<p class="text-sm text-red-400">{ errs["_"] }</p>
		</div>
	}
	<div class="space-y-4">
		@FormField("name", "Name", name, errs["name"])
		@FormField("label", "Label", label, errs["label"])
		@FormField("type", "Type", dtype, errs["type"])
		@FormSelect("parent_id", "Parent", parentID, DatatypeParentOptions(allDatatypes, ""), errs["parent_id"])
	</div>
	<div class="mt-5 sm:mt-4 sm:flex sm:flex-row-reverse">
		<button type="submit" class="inline-flex w-full justify-center rounded-md bg-indigo-500 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400 sm:ml-3 sm:w-auto">Create</button>
		<button type="button" onclick="this.closest('mcms-dialog').close()" class="mt-3 inline-flex w-full justify-center rounded-md bg-white/5 px-3 py-2 text-sm font-semibold text-white ring-1 ring-white/10 ring-inset hover:bg-white/10 sm:mt-0 sm:w-auto">Cancel</button>
	</div>
}

// DatatypeEditForm renders the edit datatype form fields.
// Used as an HTMX partial for validation error responses on the detail page.
templ DatatypeEditForm(id string, name string, label string, dtype string, parentID string, allDatatypes []db.Datatypes, errs map[string]string, csrfToken string) {
	<form hx-post={ "/admin/schema/datatypes/" + id }
	      hx-target="#datatype-edit-form"
	      hx-swap="innerHTML">
		@CSRFField(csrfToken)
		if errs["_"] != "" {
			<div class="rounded-md bg-red-500/10 p-4 ring-1 ring-red-400/20 ring-inset">
				<p class="text-sm text-red-400">{ errs["_"] }</p>
			</div>
		}
		<div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
			<div class="sm:col-span-3">
				@FormField("name", "Name", name, errs["name"])
			</div>
			<div class="sm:col-span-3">
				@FormField("label", "Label", label, errs["label"])
			</div>
			<div class="sm:col-span-3">
				@FormField("type", "Type", dtype, errs["type"])
			</div>
			<div class="sm:col-span-3">
				@FormSelect("parent_id", "Parent", parentID, DatatypeParentOptions(allDatatypes, id), errs["parent_id"])
			</div>
		</div>
	</form>
}
